        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "vsicons.dontShowNewVersionMessage": true,
    "debugpy.debugJustMyCode": false,
    "clangd.enabled": true,
    "clangd.arguments": [
        "--compile-commands-dir=build_debug",
        "-j=16"
    ],
    "C_Cpp.intelliSenseEngine": "disabled",
    "window.confirmBeforeClose": "keyboardOnly",
    "jupyter.notebookFileRoot": "${workspaceFolder}",
    "github.copilot.nextEditSuggestions.enabled": true,
    "python.analysis.diagnosticsSource": "Pyright",
    "workbench.sideBar.location": "right",
    "indentRainbow.colorOnWhiteSpaceOnly": true,
    "indentRainbow.colors": [
        "rgba(255,255,64,0.07)",
        "rgba(127,255,127,0.07)",
        "rgba(255,127,255,0.07)",
        "rgba(79,236,236,0.07)"
    ],
    "editor.glyphMargin": true,
    "vim.smartRelativeLine": true,
    "files.autoSave": "afterDelay",
    "cursor.cpp.disabledLanguages": [
        "plaintext",
        "markdown",
        "scminput"
    ],
    "multiCommand.commands": [
        {
            "command": "multiCommand.closeStuffAndMaybeToggleAux",
            "sequence": [
            "workbench.action.closePanel",
            "workbench.action.closeSidebar",
            {
                "command": "workbench.action.toggleAuxiliaryBar",
                "when": "auxiliaryBarVisible"
            }
            ]
        }
    ],
    "cursorpyright.analysis.diagnosticSeverityOverrides": {
        "reportArgumentType": "none",
        "reportOptionalMemberAccess": "none",
        "reportOptionalCall": "none",
        "reportOptionalIterable": "none",
        "reportOptionalSubscript": "none",
        "reportOptionalContextManager": "none",
        "reportOptionalOperand": "none",
        "reportCallIssue": "none",
        "reportAttributeAccessIssue": "none"
    },
    "cursorpyright.analysis.typeCheckingMode": "basic",
    "workbench.colorTheme": "Default Dark Modern",
    "git.blame.editorDecoration.enabled": true,
    "workbench.activityBar.orientation": "vertical",
    "editor.inlayHints.enabled": "off",
    "python.languageServer": "Pylance",
    "files.exclude": {
        ".venv": true
    },
    "latex-workshop.formatting.latex": "tex-fmt",
    "git.suggestSmartCommit": false,
    "editor.inlineSuggest.edits.showCollapsed": true,
    "chat.viewSessions.orientation": "stacked",
    "python.analysis.extraPaths": [
        "${workspaceFolder}"
    ],
    "python.linting.enabled": true,
    "security.workspace.trust.untrustedFiles": "open"
}
