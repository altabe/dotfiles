{
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnType": true,
        "editor.wordBasedSuggestions": "matchingDocuments"
    },
    "accessibility.dimUnfocused.enabled": true,
    "accessibility.dimUnfocused.opacity": 0.9,
    "C_Cpp.errorSquiggles": "enabled",
    "debug.allowBreakpointsEverywhere": true,
    "debug.toolBarLocation": "floating",
    "diffEditor.ignoreTrimWhitespace": false,
    "developer.logLevel": "trace",
    "editor.accessibilitySupport": "off",
    "editor.cursorSurroundingLines": 19,
    "editor.fontSize": 12,
    "editor.lineNumbers": "relative",
    "editor.minimap.enabled": false,
    "editor.stickyScroll.enabled": true,
    "files.autoSaveDelay": 300,
    "git.autofetch": true,
    "git.openRepositoryInParentFolders": "never",
    "jupyter.askForKernelRestart": false,
    "jupyter.debugJustMyCode": false,
    "notebook.output.textLineLimit": 1000,
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.diagnosticSeverityOverrides": {
        "reportArgumentType": "none",
        "reportOptionalMemberAccess": "none",
        "reportOptionalCall": "none",
        "reportOptionalIterable": "none",
        "reportOptionalSubscript": "none",
        "reportOptionalContextManager": "none",
        "reportOptionalOperand": "none",
        "reportCallIssue": "none",
        "reportAttributeAccessIssue": "none"
    },
    "python.terminal.activateEnvironment": false,
    "remote.autoForwardPortsSource": "hybrid",
    "remote.SSH.remotePlatform": {
    },
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.defaultProfile.windows": "Command Prompt",
    "terminal.integrated.rightClickBehavior": "paste",
    "terminal.integrated.scrollback": 30000,
    "window.openFoldersInNewWindow": "on",
    "workbench.colorCustomizations": {
        "scrollbar.shadow": "#ff0000",
        "tab.activeBorder": "#00ff00",
        "editor.selectionBackground": "#e788ff7c",
        "editor.selectionHighlightBackground": "#ff00005b",
        "editor.findMatchBackground": "#00cc44a8",
        "editor.findMatchHighlightBackground": "#ff7b00a1",
        "editor.wordHighlightBorder": "#FFFA0051",
        "editor.wordHighlightBackground": "#00000000",
        "numberedBookmarks.lineBackground": "#007700"
    },
    "workbench.editor.tabSizing": "fit",
    "workbench.iconTheme": "vscode-icons",
    "workbench.list.openMode": "doubleClick",
    "workbench.localHistory.enabled": true,
    "vim.leader": "<Space>",
    "github.copilot.chat.codeGeneration.useInstructionFiles": true,
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1
    },
    "vim.normalModeKeyBindings": [
        {
            "before": [
                "leader",
                "b"
